# Server Configuration
PORT=3000
HOST=127.0.0.1

# Kilo Configuration
KILO_PATH=/home/vincent/.nvm/versions/node/v24.13.1/bin/kilo

# Logging
LOG_LEVEL=info

# CORS (comma-separated origins)
CORS_ORIGINS=

# Authentication
